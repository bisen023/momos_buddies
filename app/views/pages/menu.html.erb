<div class="max-w-7xl mx-auto space-y-16 py-8">
  <section class="text-center">
    <div class="inline-block relative mb-4">
      <h1 class="text-4xl md:text-5xl font-black bg-gradient-to-r from-orange-600 to-red-600 bg-clip-text text-transparent pb-1">Our Menu</h1>
      <div class="absolute -bottom-2 left-1/2 transform -translate-x-1/2 w-24 h-1.5 bg-yellow-400 rounded-full"></div>
    </div>
    <p class="text-gray-500 font-medium text-lg mt-6">Handcrafted Momos, served hot and fresh!</p>
  </section>

  <% 
    menu_sections = [
      {
        title: "Steam Momos",
        icon: "🥟",
        image: "steam_momos.png",
        items: [
          { name: "Veg Momos", half: "29", full: "49" },
          { name: "Paneer Momos", half: "39", full: "69" },
          { name: "Cheese Corn", half: "49", full: "89" }
        ]
      },
      {
        title: "Fried Momos",
        icon: "🔥",
        image: "fried_momos.png",
        items: [
          { name: "Veg Momos", half: "39", full: "59" },
          { name: "Paneer Momos", half: "49", full: "79" },
          { name: "Cheese Corn", half: "59", full: "99" }
        ]
      },
      {
        title: "Tandoori Momos",
        icon: "🍢",
        image: "tandoori_momos.png",
        items: [
          { name: "Veg Momos", half: "45", full: "69" },
          { name: "Paneer Momos", half: "55", full: "89" },
          { name: "Cheese Corn", half: "65", full: "109" }
        ]
      }
    ]
  %>

  <div class="space-y-12 px-4 py-6">
    <% menu_sections.each do |section| %>
      <div class="group overflow-hidden rounded-[2.5rem] bg-white shadow-[0_25px_60px_rgba(249,115,22,0.12)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_30px_70px_rgba(249,115,22,0.18)]">
        <div class="flex flex-col md:flex-row">
        
        <div class="relative h-64 w-full overflow-hidden md:min-h-[350px] md:w-5/12 lg:w-1/3">
          <%= image_tag section[:image], class: "absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105", alt: section[:title] if section[:image] %>
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent flex flex-col justify-end p-6">
            <span class="text-4xl mb-2"><%= section[:icon] %></span>
            <h2 class="text-3xl font-black text-white tracking-widest uppercase drop-shadow-md"><%= section[:title] %></h2>
          </div>
        </div>

        <div class="relative w-full bg-gradient-to-br from-orange-50 to-white p-6 sm:p-10 md:w-7/12 lg:w-2/3">
          <div class="absolute right-0 top-0 p-8 opacity-5">
            <span class="text-9xl"><%= section[:icon] %></span>
          </div>

          <div class="relative z-10">
            <div class="flex justify-between items-end border-b-2 border-orange-100 pb-3 mb-6 text-xs sm:text-sm font-bold text-gray-400 uppercase tracking-widest">
              <span>Type</span>
              <div class="flex space-x-6 sm:space-x-12 pr-2 sm:pr-6">
                <span class="w-12 text-center text-orange-500">Half</span>
                <span class="w-12 text-center text-red-500">Full</span>
              </div>
            </div>

            <div class="space-y-6">
              <% section[:items].each do |item| %>
                <div class="flex justify-between items-center group/item hover:bg-orange-50 -mx-4 px-4 py-2 rounded-2xl transition-colors">
                  <span class="text-lg sm:text-xl font-extrabold text-gray-800"><%= item[:name] %></span>
                  <div class="flex space-x-6 sm:space-x-12 items-center pr-2 sm:pr-6">
                    <span class="w-12 text-center font-bold text-gray-500 text-lg">₹<%= item[:half] %></span>
                    <span class="w-12 text-center font-black text-gray-900 bg-orange-100/80 py-1.5 rounded-lg text-lg">₹<%= item[:full] %></span>
                  </div>
                </div>
              <% end %>
            </div>

            <div class="mt-8 pt-6 border-t border-gray-50">
              <a href="https://wa.me/917049652141?text=<%= ERB::Util.url_encode("I want to order #{section[:title]}") %>" target="_blank" class="inline-flex items-center rounded-full bg-orange-100 px-6 py-3 font-bold text-orange-700 transition-colors hover:bg-orange-200 hover:text-orange-800 group/btn">
                Order <%= section[:title] %> Now 
                <svg class="w-5 h-5 ml-2 group-hover/btn:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
              </a>
            </div>
          </div>
        </div>
        </div>
      </div>
    <% end %>
  </div>

  <div class="mt-12 rounded-[2rem] bg-white p-6 text-center shadow-[0_18px_45px_rgba(15,23,42,0.08)]">
    <p class="text-orange-800 font-medium">
        Gate No.2 Prakash Nagar In Front Of Shree Ram Boys Hostel Navlakha, Indore
    </p>
  </div>
</div>
