<%# ===== Reviews Section ===== %>
<div class="mt-20 mb-8 w-full max-w-7xl mx-auto px-4">
  <div class="text-center mb-10">
    <div class="inline-flex items-center justify-center rounded-full bg-yellow-100 px-4 py-1.5 mb-4 text-sm font-semibold text-yellow-700 shadow-sm border border-yellow-200">
      <span class="mr-2">⭐</span> Customer Reviews
    </div>
    <h2 class="text-4xl font-extrabold text-gray-900 mb-3">
      What Our <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-red-600">Foodies Say</span>
    </h2>
    <p class="text-gray-500 text-lg font-medium">Real reviews from real momo lovers 🥟</p>
  </div>

  <%# Overall rating pill %>
  <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-10">
    <div class="flex items-center gap-3 bg-white rounded-[2rem] px-6 py-3 shadow-lg">
      <span class="text-4xl font-black text-gray-900"><%= @average_rating.zero? ? "—" : @average_rating %></span>
      <div>
        <div class="flex gap-0.5">
          <% if @review_count > 0 %>
            <% @average_rating.floor.times { %><span class="text-yellow-400 text-xl">★</span><% } %>
            <% (5 - @average_rating.floor).times { %><span class="text-gray-200 text-xl">★</span><% } %>
          <% else %>
            <% 5.times { %><span class="text-gray-200 text-xl">★</span><% } %>
          <% end %>
        </div>
        <p class="text-xs text-gray-400 font-medium mt-0.5"><%= @review_count %> review<%= @review_count == 1 ? "" : "s" %></p>
      </div>
    </div>
    <%= link_to new_review_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-orange-500 to-red-600 text-white font-bold rounded-xl shadow-lg hover:shadow-orange-400/40 hover:-translate-y-0.5 transition-all text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" do %>
      <span>✍️</span> Write a Review
    <% end %>
  </div>

  <% if @recent_reviews.any? %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
      <% @recent_reviews.each do |review| %>
        <div class="bg-white rounded-[2rem] p-5 shadow-[0_16px_40px_rgba(15,23,42,0.10)] hover:-translate-y-1 hover:shadow-[0_24px_60px_rgba(249,115,22,0.18)] transition-all duration-300">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-orange-400 to-red-500 flex items-center justify-center text-white font-black text-base shadow-sm flex-shrink-0">
              <%= review.name.first.upcase %>
            </div>
            <div class="min-w-0">
              <p class="font-bold text-gray-900 text-sm truncate"><%= review.name %></p>
              <p class="text-xs text-gray-400"><%= review.created_at.strftime("%b %d, %Y") %></p>
            </div>
          </div>
          <div class="flex gap-0.5 mb-2">
            <% review.rating.times { %><span class="text-yellow-400 text-base">★</span><% } %>
            <% (5 - review.rating).times { %><span class="text-gray-200 text-base">★</span><% } %>
          </div>
          <p class="text-gray-500 text-xs leading-relaxed line-clamp-3"><%= review.body %></p>
        </div>
      <% end %>
    </div>

 <div class="text-center">
  <%= link_to reviews_path, class: "group inline-flex items-center gap-2 px-7 py-3 
  bg-white border border-orange-200 
  text-orange-600 font-semibold rounded-xl 
  shadow-sm hover:shadow-md 
  hover:-translate-y-0.5 
  hover:bg-orange-50 
  transition-all duration-300 
  text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" do %>

    <span>See All Reviews</span>

    <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-1" 
         fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" 
            d="M14 5l7 7m0 0l-7 7m7-7H3"/>
    </svg>

  <% end %>
</div>
</div>
  <% else %>
    <div class="text-center py-16 bg-white rounded-[2.5rem] shadow-[0_18px_48px_rgba(15,23,42,0.08)]">
      <p class="text-5xl mb-3">🥟</p>
      <p class="text-lg font-bold text-gray-700 mb-1">No reviews yet</p>
      <p class="text-gray-400 mb-5 text-sm">Be the first to share your momo experience!</p>
      <%= link_to "Write First Review", new_review_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-orange-500 to-red-600 text-white font-bold rounded-xl shadow hover:shadow-orange-300/50 hover:-translate-y-0.5 transition-all text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" %>
    </div>
  <% end %>
</div>
