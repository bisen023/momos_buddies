<%# Shared Review Form Partial %>
<%= form_with model: review, class: "space-y-6" do |f| %>

  <%# Validation errors %>
  <% if review.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-2xl p-5">
      <p class="font-bold text-red-700 mb-2">⚠️ Please fix the following:</p>
      <ul class="list-disc list-inside text-red-600 text-sm space-y-1">
        <% review.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%# Name %>
  <div>
    <%= f.label :name, "Your Name", class: "block text-sm font-bold text-gray-700 mb-1.5" %>
    <%= f.text_field :name, placeholder: "e.g. Rahul Sharma",
        class: "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-gray-900 placeholder-gray-400 font-medium text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:bg-white transition-all" %>
  </div>

  <%# Email %>
  <div>
    <%= f.label :email, "Email Address", class: "block text-sm font-bold text-gray-700 mb-1.5" %>
    <%= f.email_field :email, placeholder: "you@example.com",
        class: "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-gray-900 placeholder-gray-400 font-medium text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:bg-white transition-all" %>
    <p class="text-xs text-gray-400 mt-1 font-medium">We won't share your email with anyone.</p>
  </div>

  <%# Star Rating — interactive JS stars %>
  <div>
    <p class="block text-sm font-bold text-gray-700 mb-2">Your Rating</p>
    <div class="flex items-center gap-1" id="star-rating-widget">
      <% 5.times do |i| %>
        <label for="star-<%= i + 1 %>" class="cursor-pointer">
          <input type="radio" name="review[rating]" id="star-<%= i + 1 %>" value="<%= i + 1 %>"
                 class="sr-only peer"
                 <%= 'checked' if review.rating == i + 1 %>>
          <span class="star-label text-4xl transition-all duration-150 select-none"
                data-value="<%= i + 1 %>">☆</span>
        </label>
      <% end %>
      <span class="ml-3 text-sm font-semibold text-gray-400" id="rating-text">Click to rate</span>
    </div>
    <p class="text-xs text-gray-400 mt-1.5 font-medium">1 = Poor · 5 = Excellent</p>
  </div>

  <%# Review Body %>
  <div>
    <%= f.label :body, "Your Review", class: "block text-sm font-bold text-gray-700 mb-1.5" %>
    <%= f.text_area :body, rows: 5, placeholder: "Tell us about your experience... What did you love? What could be better?",
        class: "w-full px-4 py-3 rounded-xl border border-gray-200 bg-gray-50 text-gray-900 placeholder-gray-400 font-medium text-sm focus:outline-none focus:ring-2 focus:ring-orange-400 focus:bg-white transition-all resize-none" %>
    <p class="text-xs text-gray-400 mt-1 font-medium">Minimum 10 characters.</p>
  </div>

  <%# Submit %>
  <div class="pt-2 flex items-center gap-4">
    <%= f.submit review.new_record? ? "Submit Review 🌟" : "Update Review ✅",
        class: "inline-flex items-center px-8 py-3.5 bg-gradient-to-r from-orange-500 to-red-600 text-white font-bold rounded-xl shadow-lg hover:shadow-orange-400/40 hover:-translate-y-0.5 transition-all duration-200 cursor-pointer focus:outline-none focus:ring-2 focus:ring-orange-400 text-sm" %>
    <%= link_to "Cancel", reviews_path,
        class: "text-gray-500 font-semibold text-sm hover:text-gray-700 transition-colors" %>
  </div>

<% end %>

<script>
  (function() {
    const labels = document.querySelectorAll('.star-label');
    const ratingText = document.getElementById('rating-text');
    const descriptions = ['', 'Poor 😞', 'Fair 😐', 'Good 😊', 'Great 😄', 'Excellent 🤩'];

    function refreshStars(value) {
      labels.forEach(lbl => {
        const v = parseInt(lbl.dataset.value);
        lbl.textContent = v <= value ? '★' : '☆';
        lbl.style.color = v <= value ? '#FBBF24' : '#D1D5DB';
        lbl.style.textShadow = v <= value ? '0 0 8px rgba(251,191,36,0.4)' : 'none';
      });
      ratingText.textContent = value ? descriptions[value] : 'Click to rate';
    }

    // Init from checked radio (edit form)
    const checkedRadio = document.querySelector('input[name="review[rating]"]:checked');
    if (checkedRadio) refreshStars(parseInt(checkedRadio.value));

    // Hover
    labels.forEach(lbl => {
      lbl.addEventListener('mouseenter', () => refreshStars(parseInt(lbl.dataset.value)));
    });
    document.getElementById('star-rating-widget').addEventListener('mouseleave', () => {
      const checked = document.querySelector('input[name="review[rating]"]:checked');
      refreshStars(checked ? parseInt(checked.value) : 0);
    });

    // Click
    document.querySelectorAll('input[name="review[rating]"]').forEach(radio => {
      radio.addEventListener('change', () => refreshStars(parseInt(radio.value)));
    });
  })();
</script>
