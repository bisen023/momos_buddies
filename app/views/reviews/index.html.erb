<%# Reviews Index — Google-style rating display %>
<div class="max-w-6xl mx-auto px-4 py-8 sm:px-6">

  <%# Flash Messages %>
  <% if notice %>
    <div class="mb-6 flex items-center gap-3 bg-green-50 border border-green-200 text-green-800 rounded-2xl px-5 py-4 shadow-sm animate-fade-in-up">
      <span class="text-2xl">✅</span>
      <p class="font-semibold"><%= notice %></p>
    </div>
  <% end %>

  <%# Header %>
  <div class="text-center mb-12">
    <div class="inline-flex items-center justify-center rounded-full bg-orange-100 px-4 py-1.5 mb-4 text-sm font-semibold text-orange-700 shadow-sm border border-orange-200">
      <span class="mr-2">⭐</span> Customer Reviews
    </div>
    <h1 class="text-4xl font-extrabold text-gray-900 mb-2">
      What Our <span class="text-transparent bg-clip-text bg-gradient-to-r from-orange-500 to-red-600">Foodies Say</span>
    </h1>
    <p class="text-gray-500 text-lg font-medium">Real reviews from real momo lovers 🥟</p>
  </div>

  <%# Overall Rating Banner — Google-style %>
  <div class="bg-white/95 rounded-[2.5rem] shadow-[0_30px_60px_rgba(249,115,22,0.12)] p-8 mb-12 flex flex-col sm:flex-row items-center justify-between gap-6">
    <div class="text-center sm:text-left">
      <p class="text-6xl font-black text-gray-900"><%= @average_rating.zero? ? "—" : @average_rating %></p>
      <div class="flex items-center gap-1 mt-2 justify-center sm:justify-start">
        <% full_stars = @average_rating.floor %>
        <% half = (@average_rating - full_stars) >= 0.5 %>
        <% 5.times do |i| %>
          <% if i < full_stars %>
            <span class="text-3xl text-yellow-400">★</span>
          <% elsif i == full_stars && half %>
            <span class="text-3xl text-yellow-300">★</span>
          <% else %>
            <span class="text-3xl text-gray-300">★</span>
          <% end %>
        <% end %>
      </div>
      <p class="text-gray-400 text-sm mt-1 font-medium"><%= @reviews.count %> review<%= @reviews.count == 1 ? "" : "s" %></p>
    </div>

    <div class="flex flex-col items-center sm:items-end gap-3">
      <%= link_to new_review_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-orange-500 to-red-600 text-white font-bold rounded-xl shadow-lg hover:shadow-orange-400/40 hover:-translate-y-0.5 transition-all duration-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" do %>
        <span class="text-lg">✍️</span> Write a Review
      <% end %>
    </div>
  </div>

  <%# Review Cards %>
  <% if @reviews.any? %>
    <div class="rounded-[2.5rem] bg-white/70 p-4 shadow-[0_20px_50px_rgba(15,23,42,0.08)] sm:p-6 lg:p-8">
      <div class="mb-6 flex items-center justify-between gap-4 border-b border-orange-100 pb-4">
        <div>
          <h2 class="text-2xl font-black text-gray-900">Recent Customer Reviews</h2>
          <p class="text-sm font-medium text-gray-500">Clean spacing, easier reading, and a more polished card layout.</p>
        </div>
        <div class="hidden sm:flex items-center gap-2 rounded-full bg-orange-50 px-4 py-2 text-sm font-semibold text-orange-700 shadow-sm">
          <span>⭐</span>
          <span><%= @reviews.count %> Total</span>
        </div>
      </div>

      <div id="reviews" class="grid grid-cols-1 gap-6 sm:grid-cols-2 xl:grid-cols-3">
      <% @reviews.each do |review| %>
        <div class="group h-full rounded-[2rem] bg-white p-6 shadow-[0_18px_45px_rgba(15,23,42,0.08)] transition-all duration-300 hover:-translate-y-1.5 hover:shadow-[0_25px_55px_rgba(249,115,22,0.18)]">

          <%# Top: avatar + name + date %>
          <div class="flex items-center gap-3 mb-4">
            <div class="w-11 h-11 rounded-full bg-gradient-to-br from-orange-400 to-red-500 flex items-center justify-center text-white font-black text-lg shadow-sm flex-shrink-0">
              <%= review.name.first.upcase %>
            </div>
            <div class="flex-1 min-w-0">
              <p class="font-bold text-gray-900 truncate"><%= review.name %></p>
              <p class="text-xs text-gray-400 font-medium"><%= review.created_at.strftime("%b %d, %Y") %></p>
            </div>
            <%# Admin actions (edit/delete) %>
            <div class="flex items-center gap-2 opacity-0 group-hover:opacity-100 transition-opacity">
              <%= link_to edit_review_path(review), class: "p-1.5 rounded-lg hover:bg-orange-50 text-gray-400 hover:text-orange-500 transition-colors", title: "Edit" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/></svg>
              <% end %>
              <%= button_to review_path(review), method: :delete, data: { turbo_confirm: "Delete this review?" }, class: "p-1.5 rounded-lg hover:bg-red-50 text-gray-400 hover:text-red-500 transition-colors", title: "Delete" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"/></svg>
              <% end %>
            </div>
          </div>

          <%# Star rating row %>
          <div class="flex items-center gap-1 mb-3">
            <% review.rating.times do %>
              <span class="text-yellow-400 text-xl">★</span>
            <% end %>
            <% (5 - review.rating).times do %>
              <span class="text-gray-200 text-xl">★</span>
            <% end %>
            <span class="ml-2 text-xs font-semibold text-gray-400"><%= review.rating %>/5</span>
          </div>

          <%# Review body %>
          <p class="text-sm leading-7 text-gray-600"><%= review.body %></p>
        </div>
      <% end %>
      </div>
    </div>
  <% else %>
    <div class="text-center py-20 bg-white rounded-[2.5rem] shadow-sm">
      <p class="text-6xl mb-4">🥟</p>
      <p class="text-xl font-bold text-gray-700 mb-2">No reviews yet</p>
      <p class="text-gray-400 mb-6">Be the first to share your momo experience!</p>
      <%= link_to "Write First Review", new_review_path, class: "inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-orange-500 to-red-600 text-white font-bold rounded-xl shadow hover:shadow-orange-300/50 hover:-translate-y-0.5 transition-all focus:outline-none focus:ring-2 focus:ring-orange-400" %>
    </div>
  <% end %>

</div>
