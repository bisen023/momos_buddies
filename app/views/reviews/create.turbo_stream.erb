<%= turbo_stream.replace "review_form_card" do %>
  <div class="bg-white rounded-[2.5rem] shadow-xl p-8 sm:p-10 text-center">
    <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-100 text-4xl mb-5 shadow-sm border border-green-200">
      🎉
    </div>
    <h2 class="text-3xl font-extrabold text-gray-900">Thank You for Your Review!</h2>
    <p class="mt-3 text-gray-500 font-medium">
      We appreciate your feedback, <%= @review.name %>. Your review has been submitted successfully.
    </p>
    <% if @review.email.present? %>
      <p class="mt-2 text-sm text-green-700 font-semibold">
        A confirmation email has been sent to <%= @review.email %>.
      </p>
    <% end %>
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-center gap-3">
      <%= link_to "See All Reviews", reviews_path, class: "inline-flex items-center justify-center px-6 py-3 bg-gradient-to-r from-orange-500 to-red-600 text-white font-bold rounded-xl shadow-lg hover:shadow-orange-400/40 hover:-translate-y-0.5 transition-all duration-200 text-sm focus:outline-none focus:ring-2 focus:ring-orange-400" %>
      <%= link_to "Write Another Review", new_review_path, class: "inline-flex items-center justify-center px-6 py-3 bg-white border border-orange-200 text-orange-600 font-bold rounded-xl shadow hover:shadow-md hover:-translate-y-0.5 transition-all text-sm focus:outline-none focus:ring-2 focus:ring-orange-300" %>
    </div>
  </div>
<% end %>
